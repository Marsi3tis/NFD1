--- !u!114 &257351293
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 257351291}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 04fbc5e441f3c6448b1496963e5b841b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::GopnikEvent
  option1: 0.5
  option2: 0.5
  option1Success: 50
  option1Fail: 70
  option2Success: 20
  option2Fail: 50
  option3: 100
  option1FailDropLossPercent: 30
  option2FailDropLossPercent: 50
  option3DropLossPercent: 100
  popUpUI: {fileID: 1346404380}
  eventVariants:
  - backgroundSprite: {fileID: 0}
    titleText: Edgaras "Edga"
    characterSprite: {fileID: 4853871243001637707, guid: ef4a1c0cf35329e43a4b7a1dde71a039, type: 3}
    descriptionText: "Renkant drop\u0105 staiga prib\u0117ga neai\u0161kus individas"
    dialogueOptions:
    - "-Kas tu toks? K\u0105 \u010Dia kapstai?"
    - "-Pisi \u010Dia ir rodai k\u0105 turi"
    - "-Duodi k\u0105 turi ir laisvas"
    - "-Net nebandyk b\u0117gt, vistiek nepab\u0117gsi"
    - "-Gali jau prad\u0117t kratyt ki\u0161enes "
    gopnikBio: "Edgaras arba trumpiau \"Edga\"\n\nU\u017Esauges: Dainavoj\n\nApie:
      Turi dvyn\u012F brol\u012F, tik jis ne\u0161ioja sidabrine grandin\u0117l\u0119.
      Abu rimti kontrabandininkai Kaune. Nem\u0117gsta pa\u0161alini\u0173 savo teritorijoje.
      Intensyviai sportuoja."
  - backgroundSprite: {fileID: 0}
    titleText: "K\u0119stis \"Slaboskis\""
    characterSprite: {fileID: -2963662778264816038, guid: 1e6f23850d1b1c3439e89d1feaf67b86, type: 3}
    descriptionText: "Renkant drop\u0105 i\u0161girsti, kad tau ka\u017Ek\u0105 \u0161auki\u0105
      vietinis"
    dialogueOptions:
    - "-A girdi, k\u0105 ten renki pituchas?"
    - "-Tipo galvoji nieko nema\u010Diau?"
    - "-Normalus? Vidury dienos dropukus renka, duodi \u010Dia viska k\u0105 turi"
    - "-Nu nx, vidury miesto dropukus renka, duodi \u010Dia tik tai"
    - "-Pisi \u010Dia tik tai ir kratai ki\u0161enes"
    gopnikBio: "K\u0119stis, kitaip \u017Einomas kaip \"Slabodskis\"\n\nU\u017Eauges:
      Slabotk\u0117j\n\nApie: Slabotk\u0117s vietinis, nebijo veiksmo, ta\u010Diau
      n\u0117ra ka\u017Ekuo pasi\u017Eymintis marozas."
  - backgroundSprite: {fileID: 0}
    titleText: Deiva "Goldas"
    characterSprite: {fileID: 2243684924580697019, guid: bbb9989e5f3ce43409ef6d43e12c0f08, type: 3}
    descriptionText: "Renkant drop\u0105 priva\u017Eiuoja neai\u0161kus marozas"
    dialogueOptions:
    - "-Kokias \u010Dia varkes suki?"
    - "-E, pats laikas mokes\u010Dius susimok\u0117t rajonui."
    - "-Tai parodyk k\u0105 ten i\u0161kapstei."
    - "-Kratom ki\u0161enes, lep\u0161i."
    - -Ne tam rajone varkes suki.
    gopnikBio: "Deiva, kitaip \u017Einomas kaip \"Goldas\", d\u0117l jo pastebimos
      grandin\u0117s\n\nU\u017Eauges: \u0160ilainiuose\n\nApie: Veiksmo ir varki\u0173
      mat\u0119s marozas. Neblogai prasisuk\u0119s savo rajone, prie \u0161aib\u0173.
      Vairuoja X5'a su vardiniais numeriais \"G0LD4S\"."
  - backgroundSprite: {fileID: 0}
    titleText: "Mantas \"Manc\u0117\""
    characterSprite: {fileID: -9209271733226452194, guid: 51d645da818f05b45b48fb78fde9eabd, type: 3}
    descriptionText: "Renkant drop\u0105 pajauti kaip ka\u017Ekas pagrieb\u0117 u\u017E
      pe\u010Dio"
    dialogueOptions:
    - "-Opa, k\u0105 turim?"
    - "-Dropukus atiduodi ir skirstom\u0117s"
    - -Oi prigautas, seniuk
    - "-Dropu surinkimas, duodi \u010Dia arba \u012F barzd\u0105 gausi"
    - "-Dar daug kapstysi \u010Dia?"
    gopnikBio: "Mantas arba dar \u017Einomas kaip \"Manc\u0117\"\n\nU\u017Eauges:
      Dainavoj\n\nApie: Turi dvyn\u012F brol\u012F. Abu rimti kontrabandininkai Kaune.
      Salyginai ramus lyginant su broliu, ta\u010Diau u\u017Esiima boksu."
  - backgroundSprite: {fileID: 0}
    titleText: "Vofka \"\u0160achtioras\""
    characterSprite: {fileID: -3165423863678244916, guid: 91f7ec3f70b9ca34e885acb28638279d, type: 3}
    descriptionText: "Renkant drop\u0105 pasirodo neai\u0161kus pacukas"
    dialogueOptions:
    - "-K\u0104 \u010CIA NX DARAI "
    - -DUODI DROPUS ARBA PATS PASIIMU
    - "-JAUNIMAS, K\u0104 \u010CIA DAROM"
    - "-K\u0104 \u010CIA PRIMETI PITUCHAS? DUODI K\u0104 SURINKAI"
    - -TAU DABAR VIENA PIST?
    gopnikBio: "Vofka, labiau \u017Einomas kaip \"\u0160achtioras\"\n\nU\u017Eauges:
      \u0160an\u010Diuos\n\nApie: Neai\u0161kus, neprognozuojamas, daug kart\u0173
      sed\u0117j\u0119s. Senos kartos marozas."
  eventChance: 0.2
